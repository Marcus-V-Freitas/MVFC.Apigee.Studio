@using ApigeeLocalDev.Domain.Entities

<div class="tree-node">
    @if (Item.Type is WorkspaceItemType.Directory
                   or WorkspaceItemType.ApiProxy
                   or WorkspaceItemType.SharedFlow
                   or WorkspaceItemType.Environment)
    {
        <div class="tree-dir" @oncontextmenu="e => HandleContextMenu(e, Item)" @oncontextmenu:preventDefault="true">
            <span class="tree-caret" @onclick="ToggleExpand" @onclick:stopPropagation>@(_expanded ? "\u25bc" : "\u25ba")</span>
            <span class="tree-dir-name" @onclick="ToggleExpand" @onclick:stopPropagation>@Item.Name</span>

            @if (QuickAddCategory is not null)
            {
                <button class="tree-add-btn"
                        title="Add @Item.Name item"
                        @onclick="HandleQuickAdd"
                        @onclick:stopPropagation>+</button>
            }
        </div>

        @if (_expanded)
        {
            <div class="tree-children">
                @foreach (var child in Item.Children)
                {
                    <TreeNode Item="child"
                              SelectedFilePath="@SelectedFilePath"
                              OnFileSelected="OnFileSelected"
                              OnQuickAdd="OnQuickAdd"
                              OnContextMenu="OnContextMenu" />
                }
            </div>
        }
    }
    else
    {
        var isActive = string.Equals(Item.FullPath, SelectedFilePath, StringComparison.OrdinalIgnoreCase);
        <div class="tree-file @(isActive ? "active" : "")" 
             draggable="true"
             ondragstart="event.dataTransfer.setData('text/plain', this.getAttribute('data-payload')); event.dataTransfer.setData('application/vnd.apigee.item', this.getAttribute('data-payload'));"
             data-payload="@GetDragPayload(Item)"
             @onclick="() => OnFileSelected.InvokeAsync(Item.FullPath)"
             @oncontextmenu="e => HandleContextMenu(e, Item)" @oncontextmenu:preventDefault="true">
            <span class="tree-file-icon">&#128196;</span> @Item.Name
        </div>
    }
</div>

@code {
    // Pastas que merecem o botão "+" contextual
    // environments  -> cria novo environment (pasta + JSONs mínimos)
    // sharedflows   -> cria novo shared flow (skeleton)
    // apiproxies    -> cria novo proxy (skeleton)
    // policies      -> abre galeria de templates
    // resources / targets / proxies -> cria arquivo livre
    private static readonly HashSet<string> QuickAddFolders =
        new(StringComparer.OrdinalIgnoreCase)
        {
            "policies",
            "apiproxies",
            "sharedflows",
            "environments",
            "resources",
            "targets",
            "proxies"
        };

    [Parameter] public WorkspaceItem Item { get; set; } = default!;
    [Parameter] public string? SelectedFilePath { get; set; }
    [Parameter] public EventCallback<string> OnFileSelected { get; set; }
    /// <summary>Emite (folderAbsolutePath, folderName) para o pai abrir o modal correto.</summary>
    [Parameter] public EventCallback<(string Path, string Category)> OnQuickAdd { get; set; }
    [Parameter] public EventCallback<(Microsoft.AspNetCore.Components.Web.MouseEventArgs e, WorkspaceItem item)> OnContextMenu { get; set; }

    private bool _expanded = true;

    private string? QuickAddCategory =>
        QuickAddFolders.Contains(Item.Name) ? Item.Name.ToLowerInvariant() : null;

    private void ToggleExpand() => _expanded = !_expanded;

    private Task HandleQuickAdd()
        => OnQuickAdd.InvokeAsync((Item.FullPath, Item.Name.ToLowerInvariant()));

    private Task HandleContextMenu(Microsoft.AspNetCore.Components.Web.MouseEventArgs e, WorkspaceItem item)
        => OnContextMenu.InvokeAsync((e, item));

    private string GetDragPayload(WorkspaceItem item)
    {
        var nameWithoutExt = System.IO.Path.GetFileNameWithoutExtension(item.Name);
        var dirName = System.IO.Path.GetFileName(System.IO.Path.GetDirectoryName(item.FullPath))?.ToLowerInvariant();

        if (dirName == "policies")
        {
            return $"<Step>\n    <Name>{nameWithoutExt}</Name>\n</Step>";
        }
        if (dirName == "targets")
        {
            return $"<RouteRule name=\"{nameWithoutExt}\">\n    <TargetEndpoint>{nameWithoutExt}</TargetEndpoint>\n</RouteRule>";
        }
        if (dirName == "sharedflows")
        {
            return $"<FlowCallout name=\"FlowCallout_{nameWithoutExt}\">\n    <SharedFlowBundle>{nameWithoutExt}</SharedFlowBundle>\n</FlowCallout>";
        }

        return nameWithoutExt;
    }
}
