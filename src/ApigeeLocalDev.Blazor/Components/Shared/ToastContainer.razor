@rendermode RenderMode.InteractiveServer

<div class="toast-container" aria-live="polite" aria-atomic="false">
    @foreach (var t in _toasts)
    {
        <div class="toast toast--@t.Level.ToString().ToLower() @(t.Exiting ? "toast--exit" : "toast--enter")">
            <i data-lucide="@IconFor(t.Level)" class="toast-icon"></i>
            <span class="toast-message">@t.Message</span>
            <button class="toast-close" @onclick="() => Dismiss(t)" aria-label="Fechar">
                <i data-lucide="x"></i>
            </button>
        </div>
    }
</div>
