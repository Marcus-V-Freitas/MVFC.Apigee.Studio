@using ApigeeLocalDev.Domain.Entities

<div class="trace-viewer">
    @if (!Transactions.Any())
    {
        <div class="trace-empty">
            <i data-lucide="radio" style="width:32px;height:32px;color:var(--color-text-faint)"></i>
            <p>Nenhuma transação capturada ainda.<br/>Faça uma requisição ao proxy enquanto o trace estiver ativo.</p>
        </div>
    }
    else
    {
        @foreach (var tx in Transactions)
        {
            var isExpanded  = _expanded.Contains(tx.MessageId);
            var statusClass = tx.ResponseCode >= 500 ? "tx-error"
                            : tx.ResponseCode >= 400 ? "tx-warn"
                            : "tx-ok";

            <div class="trace-tx @statusClass">
                <button class="trace-tx-header" @onclick="() => Toggle(tx.MessageId)">
                    <span class="tx-method @(tx.RequestMethod == \"GET\" ? \"method-get\" : tx.RequestMethod == \"POST\" ? \"method-post\" : tx.RequestMethod == \"DELETE\" ? \"method-delete\" : \"method-other\")">@tx.RequestMethod</span>
                    <span class="tx-uri">@tx.RequestUri</span>
                    <span class="tx-badge badge-@(tx.ResponseCode / 100)xx">@tx.ResponseCode</span>
                    @if (tx.TotalTimeMs > 0)
                    {
                        <span class="tx-time">@tx.TotalTimeMs ms</span>
                    }
                    <i data-lucide="@(isExpanded ? \"chevron-up\" : \"chevron-down\")" class="tx-chevron"></i>
                </button>

                @if (isExpanded)
                {
                    <div class="trace-timeline">

                        @* StateChanges — separadores de fase *@
                        @foreach (var pt in tx.Points.Where(p => p.PointType == "StateChange"))
                        {
                            <div class="trace-phase-divider">
                                <i data-lucide="arrow-right" style="width:12px;height:12px"></i>
                                <span>@pt.Phase</span>
                            </div>
                        }

                        @* Políticas executadas (Execution) e condições (Condition) *@
                        @foreach (var pt in tx.Points.Where(p => p.PointType != "StateChange"))
                        {
                            var ptClass = pt.HasError ? "pt-error"
                                        : pt.PointType == "Execution" ? "pt-exec"
                                        : "pt-skip";

                            <div class="trace-point @ptClass">
                                <span class="pt-icon">
                                    @if (pt.HasError)
                                    {
                                        <i data-lucide="x-circle"></i>
                                    }
                                    else if (pt.PointType == "Execution")
                                    {
                                        <i data-lucide="play-circle"></i>
                                    }
                                    else
                                    {
                                        <i data-lucide="minus-circle"></i>
                                    }
                                </span>
                                <span class="pt-name">@pt.PolicyName</span>
                                @if (!string.IsNullOrWhiteSpace(pt.Phase))
                                {
                                    <span class="pt-phase">@pt.Phase</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(pt.Description))
                                {
                                    <span class="pt-type">@pt.Description</span>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    [Parameter] public IReadOnlyList<TraceTransaction> Transactions { get; set; } = [];

    private readonly HashSet<string> _expanded = [];

    private void Toggle(string messageId)
    {
        if (!_expanded.Add(messageId))
            _expanded.Remove(messageId);
    }
}
