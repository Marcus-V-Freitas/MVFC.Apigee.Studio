@using ApigeeLocalDev.Domain.Entities
@using ApigeeLocalDev.Domain.Interfaces
@implements IAsyncDisposable
@inject IApigeeTraceClient TraceClient
@rendermode RenderMode.InteractiveServer

<div class="card">
    <div class="card-header-row">
        <h3>Policy Trace</h3>
        <div class="trace-controls">
            <label class="input-label">
                PROXY
                <select class="input" @bind="_selectedProxy" disabled="@_proxySelectDisabled">
                    <option value="">@_proxyPlaceholder</option>
                    @foreach (var proxy in AvailableProxies)
                    {
                        <option value="@proxy">@proxy</option>
                    }
                </select>
            </label>
            <label class="input-label">
                REVISION
                <input class="input" @bind="_revision" placeholder="1" style="width:80px" disabled="@_tracing" />
            </label>
            <label class="input-label">
                ENVIRONMENT
                <input class="input" @bind="_environment" placeholder="local" style="width:100px" disabled="@_tracing" />
            </label>
            <button class="btn btn-primary" @onclick="StartTrace" disabled="@_startDisabled">
                &#9654; Start Trace
            </button>
            <button class="btn btn-ghost btn-sm btn-danger" @onclick="StopTrace" disabled="@_stopDisabled">
                &#9632; Stop
            </button>
            <button class="btn btn-ghost btn-sm" @onclick="ClearTransactions" disabled="@_tracing">
                &#128465; Clear
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <p class="error-text mt-2">@_errorMessage</p>
    }

    @if (_tracing)
    {
        <p class="help-text mt-2">
            <span class="status-dot dot-green"></span>
            Capturando tráfego na sessão <code>@_sessionId</code>&hellip;
        </p>
    }

    @if (_transactions.Count == 0 && !_tracing)
    {
        <div class="empty-trace">
            <p class="help-text">Nenhuma transação capturada. Inicie o trace e faça uma requisição para o emulator.</p>
        </div>
    }

    @foreach (var tx in _transactions)
    {
        <div class="trace-transaction @TxClass(tx)">
            <div class="tx-summary">
                <span class="tx-verb">@tx.Verb</span>
                <code class="tx-path">@tx.RequestPath</code>
                <span class="badge @BadgeClass(tx)">@tx.StatusCode</span>
                <span class="tx-id help-text">@tx.MessageId</span>
            </div>
            <div class="trace-timeline">
                @foreach (var point in tx.Points)
                {
                    <div class="trace-point @PointClass(point)">
                        <span class="policy-phase">@point.Phase</span>
                        <span class="policy-name">@point.Policy</span>
                        @if (point.DurationMs > 0)
                        {
                            <span class="duration">@point.DurationMs ms</span>
                        }
                        @if (point.Error)
                        {
                            <span class="point-error-badge">&#9888; ERRO</span>
                        }
                        else if (!point.Executed)
                        {
                            <span class="point-skip-badge">SKIP</span>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string DefaultEnvironment { get; set; } = "local";
    [Parameter] public List<string> AvailableProxies { get; set; } = [];

    private string _environment   = "local";
    private string _selectedProxy = string.Empty;
    private string _revision      = "1";
    private string? _sessionId;
    private bool _tracing;
    private string _errorMessage  = string.Empty;

    private List<TraceTransaction> _transactions = new();
    private CancellationTokenSource? _cts;

    // ── Computed properties para evitar expressões complexas em disabled ──
    private bool   _hasProxies          => AvailableProxies.Count > 0;
    private bool   _proxySelectDisabled => _tracing || !_hasProxies;
    private bool   _startDisabled       => _tracing || string.IsNullOrWhiteSpace(_selectedProxy);
    private bool   _stopDisabled        => !_tracing;
    private string _proxyPlaceholder    => _hasProxies ? "-- selecione --" : "Selecione um workspace";

    // ── Computed CSS classes (evitam ternários inline no markup) ──────────
    private static string TxClass(TraceTransaction tx)    => tx.StatusCode >= 400 ? "trace-transaction tx-error" : "trace-transaction tx-ok";
    private static string BadgeClass(TraceTransaction tx) => tx.StatusCode >= 400 ? "badge badge-error" : "badge badge-success";
    private static string PointClass(TracePoint point)    => point.Error ? "trace-point point-error" : point.Executed ? "trace-point point-ok" : "trace-point point-skip";

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(_selectedProxy) && !AvailableProxies.Contains(_selectedProxy))
            _selectedProxy = string.Empty;

        _environment = DefaultEnvironment;
    }

    private async Task StartTrace()
    {
        if (string.IsNullOrWhiteSpace(_selectedProxy)) return;

        _errorMessage = string.Empty;
        _cts = new CancellationTokenSource();

        try
        {
            var session = await TraceClient.CreateSessionAsync(
                _environment, _selectedProxy, _revision, _cts.Token);
            _sessionId = session.SessionId;
            _tracing   = true;
            _ = Task.Run(() => PollAsync(_cts.Token), _cts.Token);
        }
        catch (Exception ex)
        {
            _errorMessage = "Erro ao iniciar trace: " + ex.Message;
        }
    }

    private async Task StopTrace()
    {
        _tracing = false;
        _cts?.Cancel();

        if (_sessionId is not null)
        {
            try { await TraceClient.DeleteSessionAsync(_environment, _selectedProxy, _revision, _sessionId); }
            catch { /* best-effort */ }
            _sessionId = null;
        }
    }

    private void ClearTransactions() => _transactions.Clear();

    private async Task PollAsync(CancellationToken ct)
    {
        while (!ct.IsCancellationRequested && _tracing)
        {
            try
            {
                var ids = await TraceClient.GetTransactionIdsAsync(
                    _environment, _selectedProxy, _revision, _sessionId!, ct);

                var existingIds = _transactions.Select(t => t.MessageId).ToHashSet();
                var newIds = ids.Where(id => !existingIds.Contains(id)).ToList();

                foreach (var msgId in newIds)
                {
                    var detail = await TraceClient.GetTransactionDetailAsync(
                        _environment, _selectedProxy, _revision, _sessionId!, msgId, ct);
                    _transactions.Add(detail);
                }

                if (newIds.Count > 0)
                    await InvokeAsync(StateHasChanged);
            }
            catch (OperationCanceledException) { break; }
            catch (Exception ex)
            {
                await InvokeAsync(() =>
                {
                    _errorMessage = "Erro no polling: " + ex.Message;
                    StateHasChanged();
                });
                break;
            }

            await Task.Delay(2000, ct).ConfigureAwait(false);
        }
    }

    public async ValueTask DisposeAsync()
    {
        _tracing = false;
        _cts?.Cancel();
        _cts?.Dispose();

        if (_sessionId is not null)
        {
            try { await TraceClient.DeleteSessionAsync(_environment, _selectedProxy, _revision, _sessionId); }
            catch { /* best-effort */ }
        }
    }
}
