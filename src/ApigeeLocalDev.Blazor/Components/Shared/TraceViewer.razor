@using ApigeeLocalDev.Domain.Entities
@using ApigeeLocalDev.Domain.Interfaces
@implements IAsyncDisposable
@inject IProxyTraceService TraceService
@inject NavigationManager Nav
@rendermode RenderMode.InteractiveServer

<div class="card">
    <div class="card-header-row">
        <h3>Policy Trace</h3>
        <div class="trace-controls">
            @if (AvailableProxies is { Count: > 0 })
            {
                <label class="input-label">
                    PROXY
                    <select class="input" @bind="_selectedProxy" disabled="@_tracing" style="width:160px">
                        <option value="">-- todos --</option>
                        @foreach (var p in AvailableProxies)
                        {
                            <option value="@p">@p</option>
                        }
                    </select>
                </label>
            }
            <label class="input-label">
                ENVIRONMENT
                <input class="input" @bind="_environment" placeholder="local" style="width:100px" disabled="@_tracing" />
            </label>
            <button class="btn btn-primary" @onclick="StartTrace" disabled="@_startDisabled">
                &#9654; Start Trace
            </button>
            <button class="btn btn-ghost btn-sm btn-danger" @onclick="StopTrace" disabled="@_stopDisabled">
                &#9632; Stop
            </button>
            <button class="btn btn-ghost btn-sm" @onclick="ClearTransactions" disabled="@_tracing">
                &#128465; Clear
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <p class="error-text mt-2">@_errorMessage</p>
    }

    @if (_tracing)
    {
        <p class="help-text mt-2">
            <span class="status-dot dot-green"></span>
            Capturando tráfego via <code>/emulator-runtime/**</code>&hellip;
            Faça requisições para <code>@_proxyBaseUrl/emulator-runtime/seu-path</code>
        </p>
    }

    @if (!_visibleTransactions.Any() && !_tracing)
    {
        <div class="empty-trace">
            <p class="help-text">Nenhuma transação capturada. Inicie o trace e faça uma requisição para o emulator.</p>
        </div>
    }

    @foreach (var tx in _visibleTransactions)
    {
        <div class="@TxClass(tx)">
            <div class="tx-summary">
                <span class="tx-verb">@tx.Verb</span>
                <code class="tx-path">@tx.RequestPath</code>
                <span class="@BadgeClass(tx)">@tx.StatusCode</span>
                <span class="tx-duration help-text">@tx.DurationMs ms</span>
                <span class="tx-id help-text">@tx.MessageId</span>
            </div>

            @if (!string.IsNullOrWhiteSpace(tx.RequestBody))
            {
                <details class="tx-body">
                    <summary class="help-text">Request body</summary>
                    <pre><code>@tx.RequestBody</code></pre>
                </details>
            }

            @if (!string.IsNullOrWhiteSpace(tx.ResponseBody))
            {
                <details class="tx-body">
                    <summary class="help-text">Response body</summary>
                    <pre><code>@tx.ResponseBody</code></pre>
                </details>
            }
        </div>
    }
</div>

@code {
    [Parameter] public string DefaultEnvironment { get; set; } = "local";

    /// <summary>
    /// Lista de API proxies disponíveis no workspace selecionado.
    /// Quando fornecida, exibe um seletor para filtrar transações por proxy.
    /// </summary>
    [Parameter] public List<string>? AvailableProxies { get; set; }

    private string _environment   = "local";
    private string _selectedProxy = string.Empty;
    private bool   _tracing;
    private string _errorMessage  = string.Empty;

    // URL base derivada do NavigationManager para exibir no help text
    private string _proxyBaseUrl  = "http://localhost:5000";

    private readonly List<TraceTransaction> _transactions = [];
    private CancellationTokenSource? _cts;

    private bool _startDisabled => _tracing;
    private bool _stopDisabled  => !_tracing;

    /// <summary>Filtra por proxy se um estiver selecionado.</summary>
    private IEnumerable<TraceTransaction> _visibleTransactions =>
        string.IsNullOrEmpty(_selectedProxy)
            ? _transactions
            : _transactions.Where(tx =>
                tx.RequestPath.Contains(_selectedProxy, StringComparison.OrdinalIgnoreCase));

    private static string TxClass(TraceTransaction tx)    => tx.StatusCode >= 400 ? "trace-transaction tx-error" : "trace-transaction tx-ok";
    private static string BadgeClass(TraceTransaction tx) => tx.StatusCode >= 400 ? "badge badge-error" : "badge badge-success";

    protected override void OnParametersSet() => _environment = DefaultEnvironment;

    protected override void OnInitialized()
    {
        // Deriva a URL base real da aplicação para exibir no help text
        var uri = new Uri(Nav.BaseUri);
        _proxyBaseUrl = $"{uri.Scheme}://{uri.Host}:{uri.Port}";
    }

    private void StartTrace()
    {
        _errorMessage = string.Empty;
        _cts = new CancellationTokenSource();
        TraceService.Start();
        _tracing = true;
        _ = ConsumeTraceAsync(_cts.Token);
    }

    private void StopTrace()
    {
        _tracing = false;
        TraceService.Stop();
        _cts?.Cancel();
        _cts?.Dispose();
        _cts = null;
    }

    private void ClearTransactions() => _transactions.Clear();

    private async Task ConsumeTraceAsync(CancellationToken ct)
    {
        try
        {
            await foreach (var tx in TraceService.ReadAllAsync(ct))
            {
                _transactions.Add(tx);
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { /* normal ao parar */ }
        catch (Exception ex)
        {
            await InvokeAsync(() =>
            {
                _errorMessage = "Erro no trace: " + ex.Message;
                StateHasChanged();
            });
        }
    }

    public ValueTask DisposeAsync()
    {
        StopTrace();
        return ValueTask.CompletedTask;
    }
}
