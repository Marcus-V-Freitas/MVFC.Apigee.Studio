@using ApigeeLocalDev.Domain.Entities

<div class="trace-viewer">
    @if (!Transactions.Any())
    {
        <div class="trace-empty">
            <i data-lucide="radio" style="width:32px;height:32px;color:var(--color-text-faint)"></i>
            <p>Nenhuma transação capturada ainda.<br/>Faça uma requisição ao proxy enquanto o trace estiver ativo.</p>
        </div>
    }
    else
    {
        @foreach (var tx in Transactions)
        {
            var isExpanded = _expanded.Contains(tx.MessageId);
            var statusClass = tx.StatusCode >= 500 ? "tx-error"
                            : tx.StatusCode >= 400 ? "tx-warn"
                            : "tx-ok";

            <div class="trace-tx @statusClass">
                <button class="trace-tx-header" @onclick="() => Toggle(tx.MessageId)">
                    <span class="tx-method">@tx.Verb</span>
                    <span class="tx-uri">@tx.RequestPath</span>
                    <span class="tx-badge @statusClass">@tx.StatusCode</span>
                    <span class="tx-time">@tx.DurationMs ms</span>
                    <i data-lucide="@(isExpanded ? "chevron-up" : "chevron-down")" class="tx-chevron"></i>
                </button>

                @if (isExpanded)
                {
                    <div class="trace-timeline">
                        @foreach (var pt in tx.Points)
                        {
                            var ptClass = pt.Error    ? "pt-error"
                                        : pt.Executed ? "pt-exec"
                                        : "pt-skip";

                            <div class="trace-point @ptClass">
                                <span class="pt-icon">
                                    @if (pt.Error)    { <i data-lucide="x-circle"></i>           }
                                    else if (pt.Executed) { <i data-lucide="play-circle"></i>    }
                                    else              { <i data-lucide="minus-circle"></i>        }
                                </span>
                                <span class="pt-name">@(string.IsNullOrWhiteSpace(pt.Policy) ? pt.Phase : pt.Policy)</span>
                                @if (!string.IsNullOrWhiteSpace(pt.Phase))
                                {
                                    <span class="pt-phase">@pt.Phase</span>
                                }
                                @if (pt.DurationMs > 0)
                                {
                                    <span class="pt-ms">@pt.DurationMs ms</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(pt.Condition))
                                {
                                    <span class="pt-desc">@pt.Condition</span>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    [Parameter] public IReadOnlyList<TraceTransaction> Transactions { get; set; } = [];

    private readonly HashSet<string> _expanded = [];

    private void Toggle(string messageId)
    {
        if (!_expanded.Add(messageId))
            _expanded.Remove(messageId);
    }
}
