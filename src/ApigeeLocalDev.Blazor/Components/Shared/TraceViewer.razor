@using ApigeeLocalDev.Domain.Entities
@using Microsoft.AspNetCore.Components

<div class="trace-viewer">
    @if (!Transactions.Any())
    {
        <div class="trace-empty">
            <i data-lucide="radio" style="width:32px;height:32px;color:var(--color-text-faint)"></i>
            <p>Nenhuma transação capturada ainda.<br />Faça uma requisição ao proxy enquanto o trace estiver ativo.</p>
        </div>
    }
    else
    {
        <div class="trace-list">
            @foreach (var tx in Transactions)
            {
                var isExpanded  = _expanded.Contains(tx.MessageId);
                var statusClass = tx.ResponseCode >= 500 ? "status-5xx"
                                : tx.ResponseCode >= 400 ? "status-4xx"
                                : "status-2xx";
                var methodClass = tx.RequestMethod switch
                {
                    "GET"    => "method-get",
                    "POST"   => "method-post",
                    "PUT"    => "method-put",
                    "DELETE" => "method-delete",
                    "PATCH"  => "method-patch",
                    _        => "method-other"
                };

                <div class="trace-tx">

                    @* ── Cabeçalho da transação (clicável) ── *@
                    <button class="trace-tx-header @statusClass" @onclick="() => Toggle(tx.MessageId)">
                        <span class="tx-method @methodClass">@tx.RequestMethod</span>
                        <span class="tx-uri">@tx.RequestUri</span>
                        <div class="tx-meta">
                            <span class="tx-badge @statusClass">@tx.ResponseCode</span>
                            @if (tx.TotalTimeMs > 0)
                            {
                                <span class="tx-time">@tx.TotalTimeMs ms</span>
                            }
                            <span class="tx-points-count">@tx.Points.Count step(s)</span>
                        </div>
                        <i data-lucide="@(isExpanded ? "chevron-up" : "chevron-down")" class="tx-chevron"></i>
                    </button>

                    @* ── Timeline expandida ── *@
                    @if (isExpanded)
                    {
                        <div class="trace-timeline">
                            @foreach (var pt in tx.Points)
                            {
                                @if (pt.PointType == "StateChange")
                                {
                                    @* Separador de fase — linha horizontal com label *@
                                    <div class="tl-phase-divider">
                                        <span class="tl-phase-line"></span>
                                        <span class="tl-phase-label @PhaseClass(pt.PolicyName)">@pt.PolicyName</span>
                                        <span class="tl-phase-line"></span>
                                    </div>
                                }
                                else if (pt.PointType == "Condition")
                                {
                                    @* Condição avaliada — ícone de filtro com expressão *@
                                    var condPassed = pt.Description?.Equals("true", StringComparison.OrdinalIgnoreCase) == true;
                                    <div class="tl-row tl-condition @(condPassed ? "cond-pass" : "cond-fail")">
                                        <span class="tl-connector"></span>
                                        <span class="tl-dot dot-cond"></span>
                                        <i data-lucide="@(condPassed ? "check" : "x")" class="tl-icon"></i>
                                        <span class="tl-label">@pt.PolicyName</span>
                                        <span class="tl-badge cond-badge">@(condPassed ? "true" : "false")</span>
                                    </div>
                                }
                                else
                                {
                                    @* Execution — política executada *@
                                    var execClass = pt.HasError ? "exec-error" : "exec-ok";
                                    <div class="tl-row tl-execution @execClass">
                                        <span class="tl-connector"></span>
                                        <span class="tl-dot @(pt.HasError ? "dot-error" : "dot-exec")"></span>
                                        <i data-lucide="@(pt.HasError ? "x-circle" : "play-circle")" class="tl-icon"></i>
                                        <span class="tl-label">@pt.PolicyName</span>
                                        @if (!string.IsNullOrWhiteSpace(pt.Phase))
                                        {
                                            <span class="tl-badge phase-badge">@pt.Phase</span>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(pt.Description))
                                        {
                                            <span class="tl-type">@pt.Description</span>
                                        }
                                        @if (pt.ElapsedTimeMs > 0)
                                        {
                                            <span class="tl-time">@pt.ElapsedTimeMs ms</span>
                                        }
                                    </div>
                                }
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public IReadOnlyList<TraceTransaction> Transactions { get; set; } = [];

    private readonly HashSet<string> _expanded = [];

    private void Toggle(string messageId)
    {
        if (!_expanded.Add(messageId))
            _expanded.Remove(messageId);
    }

    private static string PhaseClass(string phase) => phase switch
    {
        "REQ_HEADERS_PARSED" or "PROXY_REQ_FLOW" => "phase-proxy-req",
        "TARGET_REQ_FLOW"    or "REQ_SENT"        => "phase-target-req",
        "RESP_START"         or "TARGET_RESP_FLOW"=> "phase-target-resp",
        "PROXY_RESP_FLOW"    or "RESP_SENT"       => "phase-proxy-resp",
        _ => "phase-generic"
    };
}
