@page "/workspace/{WorkspaceName}"
@using ApigeeLocalDev.Domain.Entities
@using ApigeeLocalDev.Domain.Interfaces
@using ApigeeLocalDev.Application.UseCases
@using ApigeeLocalDev.Blazor.Services
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@inject IWorkspaceRepository WorkspaceRepo
@inject DeployToEmulatorUseCase DeployUseCase
@inject IPolicyTemplateRepository TemplateRepo
@inject GeneratePolicyUseCase GeneratePolicy
@inject ToastService Toast
@inject IJSRuntime JS
@implements IAsyncDisposable
@rendermode RenderMode.InteractiveServer

<h1>@WorkspaceName</h1>

@if (_workspace is null)
{
    <p class="error-text">Workspace não encontrado.</p>
}
else
{
    <div class="workspace-detail">
        @* ÁRVORE *@
        <aside class="file-tree">
            <div class="file-tree-header">
                <h3>Files</h3>
                <div class="file-tree-actions">
                    <button class="btn btn-ghost btn-sm" @onclick="() => OpenNewItemDialog(false)">+ File</button>
                    <button class="btn btn-ghost btn-sm" @onclick="() => OpenNewItemDialog(true)">+ Folder</button>
                </div>
            </div>

            @if (_showNewItem)
            {
                <div class="new-item-form">
                    <input class="input" @bind="_newItemName"
                           placeholder="@NewItemPlaceholder"
                           @onkeydown="HandleNewItemKey" />
                    <div class="form-actions">
                        <button class="btn btn-primary btn-sm" @onclick="ConfirmNewItem">OK</button>
                        <button class="btn btn-ghost btn-sm" @onclick="() => _showNewItem = false">&#10005;</button>
                    </div>
                    @if (!string.IsNullOrEmpty(_newItemError))
                    {
                        <p class="error-text">@_newItemError</p>
                    }
                </div>
            }

            @if (_tree is not null)
            {
                <TreeNode Item="_tree"
                          OnFileSelected="LoadFile"
                          OnQuickAdd="OpenQuickAddModal" />
            }
        </aside>

        @* MONACO EDITOR *@
        <section class="file-editor">
            @if (_selectedFile is not null)
            {
                <div class="editor-header">
                    <span class="editor-filename">@System.IO.Path.GetFileName(_selectedFile)</span>
                    <div class="editor-header-actions">
                        <button class="btn btn-ghost btn-sm" title="Format (Alt+Shift+F)" @onclick="FormatDocument">&#10024; Format</button>
                        <button class="btn btn-ghost btn-sm btn-danger" @onclick="DeleteSelectedFile">&#128465; Delete</button>
                        <button class="btn btn-primary btn-sm" @onclick="SaveFile">&#128190; Save</button>
                    </div>
                </div>
                <div id="monaco-editor-container"
                     class="monaco-container"
                     @onmonaco-save="SaveFile">
                </div>
            }
            else
            {
                <div class="empty-state">Selecione ou crie um arquivo para editar.</div>
            }
        </section>
    </div>

    @* MODAL QUICK ADD *@
    @if (_quickAddOpen)
    {
        <div class="modal-backdrop" @onclick="CloseQuickAdd">
            <div class="modal-drawer" @onclick:stopPropagation>

                <div class="modal-header">
                    <div>
                        <h3>Adicionar em <code>@_quickAddCategory</code></h3>
                        <p class="modal-path">@_quickAddPath</p>
                    </div>
                    <button class="btn btn-ghost btn-sm" @onclick="CloseQuickAdd">&#10005;</button>
                </div>

                @if (_quickAddCategory == "policies")
                {
                    <div class="drawer-body">
                        <div class="drawer-list">
                            @foreach (var group in _allTemplates.GroupBy(t => t.Category))
                            {
                                <div class="drawer-group">
                                    <span class="drawer-group-label">@group.Key</span>
                                    @foreach (var t in group)
                                    {
                                        var isActive = t == _quickTemplate;
                                        <button class="@(isActive ? "drawer-item drawer-item--active" : "drawer-item")"
                                                @onclick="() => SelectQuickTemplate(t)">
                                            <span class="drawer-item-name">@t.Name</span>
                                            @if (!string.IsNullOrEmpty(t.Description))
                                            {
                                                <span class="drawer-item-desc">@t.Description</span>
                                            }
                                        </button>
                                    }
                                </div>
                            }
                        </div>

                        <div class="drawer-form">
                            @if (_quickTemplate is null)
                            {
                                <div class="drawer-empty">
                                    <span>&larr; Selecione um template</span>
                                </div>
                            }
                            else
                            {
                                <h4>@_quickTemplate.Name</h4>
                                @if (!string.IsNullOrEmpty(_quickTemplate.Description))
                                {
                                    <p class="help-text">@_quickTemplate.Description</p>
                                }

                                <div class="param-list">
                                    @foreach (var p in _quickTemplate.Parameters)
                                    {
                                        <label>
                                            @p
                                            <input class="input" value="@GetQParam(p)"
                                                   @onchange="e => SetQParam(p, e.Value?.ToString() ?? string.Empty)" />
                                        </label>
                                    }
                                </div>

                                <button class="btn btn-primary" @onclick="ConfirmQuickPolicy"
                                        disabled="@_quickGenerating">
                                    @(_quickGenerating ? "Gerando..." : "Gerar Política")
                                </button>

                                @if (!string.IsNullOrEmpty(_quickMessage))
                                {
                                    <p class="mt-2 @QuickMessageClass">@_quickMessage</p>
                                }
                            }
                        </div>
                    </div>
                }
                else if (_quickAddCategory == "sharedflows")
                {
                    <div class="drawer-body drawer-body--single">
                        <label>
                            Nome do Shared Flow
                            <input class="input" @bind="_quickFileName" placeholder="meu-shared-flow" />
                        </label>
                        <button class="btn btn-primary" @onclick="ConfirmQuickSharedFlow">Criar Shared Flow</button>
                        @if (!string.IsNullOrEmpty(_quickMessage))
                        {
                            <p class="mt-2 @QuickMessageClass">@_quickMessage</p>
                        }
                    </div>
                }
                else if (_quickAddCategory == "environments")
                {
                    <div class="drawer-body drawer-body--single">
                        <label>
                            Nome do Environment
                            <input class="input" @bind="_quickFileName" placeholder="local" />
                        </label>
                        <p class="help-text">Cria a pasta do environment com arquivos mínimos (deployments.json, flowhooks.json, targetservers.json).</p>
                        <button class="btn btn-primary" @onclick="ConfirmQuickEnvironment">Criar Environment</button>
                        @if (!string.IsNullOrEmpty(_quickMessage))
                        {
                            <p class="mt-2 @QuickMessageClass">@_quickMessage</p>
                        }
                    </div>
                }
                else
                {
                    var labelText       = _quickAddCategory == "apiproxies" ? "Nome da API (proxy)" : "Nome do arquivo";
                    var placeholderText = _quickAddCategory == "apiproxies" ? "minha-api" : "meu-recurso.xml";
                    var btnText         = _quickAddCategory == "apiproxies" ? "Criar API" : "Criar Arquivo";

                    <div class="drawer-body drawer-body--single">
                        <label>
                            @labelText
                            <input class="input" @bind="_quickFileName" placeholder="@placeholderText" />
                        </label>
                        <button class="btn btn-primary" @onclick="ConfirmQuickFile">@btnText</button>
                        @if (!string.IsNullOrEmpty(_quickMessage))
                        {
                            <p class="mt-2 @QuickMessageClass">@_quickMessage</p>
                        }
                    </div>
                }
            </div>
        </div>
    }

    @* DEPLOY PANEL *@
    <div class="deploy-panel card">
        <h3>Deploy to Emulator</h3>
        <div class="deploy-tabs">
            <button class="@TabClass(DeployModeFull)"  @onclick="SetDeployModeFull">Workspace completo</button>
            <button class="@TabClass(DeployModeProxy)" @onclick="SetDeployModeProxy">Proxy / Shared Flow</button>
        </div>

        @if (_deployMode == DeployModeProxy)
        {
            <div class="deploy-form">
                <label>Proxy / Shared Flow name
                    <input class="input" @bind="_deployTarget" placeholder="my-proxy" />
                </label>
                <label>Environment
                    <input class="input" @bind="_deployEnv" placeholder="local" />
                </label>
                <button class="btn btn-primary" @onclick="DeployProxy" disabled="@_deploying">
                    @(_deploying ? "Deploying..." : "Deploy")
                </button>
            </div>
        }
        else
        {
            <div class="deploy-form">
                <label>Environment
                    <input class="input" @bind="_deployEnv" placeholder="local" />
                </label>
                <button class="btn btn-primary" @onclick="DeployFull" disabled="@_deploying">
                    @(_deploying ? "Deploying..." : "Deploy workspace completo")
                </button>
            </div>
        }

        @if (!string.IsNullOrEmpty(_deployMessage))
        {
            <p class="@DeployMessageClass">@_deployMessage</p>
        }
    </div>
}

@code {
    private const string EditorId        = "monaco-editor-container";
    private const string DeployModeProxy = "proxy";
    private const string DeployModeFull  = "full";

    [Parameter] public string WorkspaceName { get; set; } = string.Empty;

    private ApigeeWorkspace? _workspace;
    private WorkspaceItem?   _tree;
    private string?          _selectedFile;
    private string           _fileContent = string.Empty;

    private bool   _showNewItem;
    private bool   _newItemIsDir;
    private string _newItemName  = string.Empty;
    private string _newItemError = string.Empty;

    private string _deployTarget  = string.Empty;
    private string _deployEnv     = "local";
    private string _deployMode    = DeployModeFull;
    private bool   _deploying;
    private string _deployMessage = string.Empty;
    private bool   _deployError;

    private bool   _quickAddOpen     = false;
    private string _quickAddPath     = string.Empty;
    private string _quickAddCategory = string.Empty;
    private IReadOnlyList<PolicyTemplate> _allTemplates = [];
    private PolicyTemplate? _quickTemplate;
    private Dictionary<string, string> _quickParams = [];
    private string _quickFileName   = string.Empty;
    private string _quickMessage    = string.Empty;
    private bool   _quickError;
    private bool   _quickGenerating;

    private string NewItemPlaceholder => _newItemIsDir ? "folder-name" : "file.xml";
    private string DeployMessageClass => _deployError ? "error-text" : "success-text";
    private string QuickMessageClass  => _quickError  ? "error-text" : "success-text";
    private string TabClass(string m) => _deployMode == m ? "btn btn-primary btn-sm" : "btn btn-ghost btn-sm";

    private void SetDeployModeProxy() => _deployMode = DeployModeProxy;
    private void SetDeployModeFull()  => _deployMode = DeployModeFull;

    protected override async Task OnInitializedAsync()
    {
        _workspace    = WorkspaceRepo.ListAll().FirstOrDefault(w => w.Name == WorkspaceName);
        _allTemplates = TemplateRepo.GetAll();
        if (_workspace is not null)
            _tree = await WorkspaceRepo.LoadTreeAsync(_workspace);
    }

    // OnAfterRenderAsync não cria o editor.
    // LoadFile é a única fonte de criação/recriação do Monaco.
    // Isso elimina a corrida entre OnAfterRenderAsync e LoadFile que causava
    // dois editores empilhados no mesmo div (quebrando backspace e troca de arquivo).
    protected override Task OnAfterRenderAsync(bool firstRender) => Task.CompletedTask;

    private async Task LoadFile(string path)
    {
        // 1. Descarta editor anterior se existir
        await JS.InvokeVoidAsync("monacoInterop.dispose", EditorId);

        // 2. Atualiza estado
        _selectedFile = path;
        _fileContent  = await WorkspaceRepo.ReadFileAsync(path);

        // 3. Força Blazor a renderizar o container div antes de criar o editor
        StateHasChanged();
        await Task.Yield();

        // 4. Cria o editor com o conteúdo correto
        await JS.InvokeVoidAsync(
            "monacoInterop.create",
            EditorId,
            _fileContent,
            _selectedFile);
    }

    private async Task SaveFile()
    {
        if (_selectedFile is null) return;
        _fileContent = await JS.InvokeAsync<string>("monacoInterop.getValue", EditorId);
        await WorkspaceRepo.SaveFileAsync(_selectedFile, _fileContent);
        Toast.ShowSuccess("✔ Arquivo salvo com sucesso!");
    }

    private async Task FormatDocument()
    {
        if (_selectedFile is null) return;
        await JS.InvokeVoidAsync("monacoInterop.formatDocument", EditorId);
    }

    private async Task DeleteSelectedFile()
    {
        if (_selectedFile is null || _workspace is null) return;
        var fileName = System.IO.Path.GetFileName(_selectedFile);
        var confirm  = await JS.InvokeAsync<bool>("confirm", "Remover arquivo '" + fileName + "'?");
        if (!confirm) return;

        await JS.InvokeVoidAsync("monacoInterop.dispose", EditorId);
        await WorkspaceRepo.DeleteFileAsync(_selectedFile);
        _selectedFile = null;
        _fileContent  = string.Empty;
        _tree         = await WorkspaceRepo.LoadTreeAsync(_workspace);
        Toast.ShowSuccess("✔ Arquivo '" + fileName + "' removido.");
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("monacoInterop.dispose", EditorId); }
        catch { /* JS runtime pode já estar descartado */ }
    }

    private void OpenNewItemDialog(bool isDir)
    {
        _newItemIsDir = isDir;
        _newItemName  = _newItemError = string.Empty;
        _showNewItem  = true;
    }

    private async Task HandleNewItemKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")  await ConfirmNewItem();
        if (e.Key == "Escape") _showNewItem = false;
    }

    private async Task ConfirmNewItem()
    {
        _newItemError = string.Empty;
        if (string.IsNullOrWhiteSpace(_newItemName)) { _newItemError = "Informe um nome."; return; }
        if (_workspace is null) return;

        var basePath = _selectedFile is not null
            ? System.IO.Path.GetDirectoryName(_selectedFile)!
            : _workspace.RootPath;
        var fullPath = System.IO.Path.Combine(basePath, _newItemName);
        try
        {
            if (_newItemIsDir) await WorkspaceRepo.CreateDirectoryAsync(fullPath);
            else { await WorkspaceRepo.CreateFileAsync(fullPath); await LoadFile(fullPath); }
            _showNewItem = false;
            _tree = await WorkspaceRepo.LoadTreeAsync(_workspace);
        }
        catch (Exception ex) { _newItemError = ex.Message; }
    }

    private void OpenQuickAddModal((string Path, string Category) args)
    {
        _quickAddPath     = args.Path;
        _quickAddCategory = args.Category;
        _quickTemplate    = null;
        _quickParams      = [];
        _quickFileName    = string.Empty;
        _quickMessage     = string.Empty;
        _quickError       = false;
        _quickAddOpen     = true;
    }

    private void CloseQuickAdd() => _quickAddOpen = false;

    private void SelectQuickTemplate(PolicyTemplate t)
    {
        _quickTemplate = t;
        _quickParams   = t.Parameters.ToDictionary(p => p, _ => string.Empty);
        if (_quickParams.ContainsKey("PolicyName")) _quickParams["PolicyName"] = t.Name + "Policy";
    }

    private string GetQParam(string k) => _quickParams.TryGetValue(k, out var v) ? v : string.Empty;
    private void   SetQParam(string k, string v) => _quickParams[k] = v;

    private async Task ConfirmQuickPolicy()
    {
        if (_quickTemplate is null || _workspace is null) return;
        _quickGenerating = true;
        _quickMessage    = string.Empty;
        _quickError      = false;
        try
        {
            var path = await GeneratePolicy.ExecuteAtPathAsync(
                _quickAddPath,
                _quickTemplate.Name,
                _quickParams);

            _quickMessage = "✔ Criado: " + System.IO.Path.GetFileName(path);
            _tree = await WorkspaceRepo.LoadTreeAsync(_workspace);
            Toast.ShowSuccess("Política '" + System.IO.Path.GetFileName(path) + "' criada.");
            await LoadFile(path);
            CloseQuickAdd();
        }
        catch (Exception ex) { _quickMessage = "✘ " + ex.Message; _quickError = true; }
        finally { _quickGenerating = false; }
    }

    private async Task ConfirmQuickFile()
    {
        if (string.IsNullOrWhiteSpace(_quickFileName) || _workspace is null) return;
        _quickMessage = string.Empty;
        _quickError   = false;
        try
        {
            if (string.Equals(_quickAddCategory, "apiproxies", StringComparison.OrdinalIgnoreCase))
            {
                await CreateApiProxySkeletonAsync();
            }
            else
            {
                var fullPath = System.IO.Path.Combine(_quickAddPath, _quickFileName);
                await WorkspaceRepo.CreateFileAsync(fullPath);
                await LoadFile(fullPath);
                _quickAddOpen = false;
                _tree = await WorkspaceRepo.LoadTreeAsync(_workspace);
            }
        }
        catch (Exception ex) { _quickMessage = "✘ " + ex.Message; _quickError = true; }
    }

    private async Task ConfirmQuickSharedFlow()
    {
        if (string.IsNullOrWhiteSpace(_quickFileName) || _workspace is null) return;
        _quickMessage = string.Empty;
        _quickError   = false;
        try
        {
            var name   = _quickFileName.Trim();
            var sfDir  = System.IO.Path.Combine(_workspace.RootPath, "sharedflows", name, "sharedflowbundle");
            var polDir = System.IO.Path.Combine(sfDir, "policies");
            var resDir = System.IO.Path.Combine(sfDir, "sharedflows");

            await WorkspaceRepo.CreateDirectoryAsync(sfDir);
            await WorkspaceRepo.CreateDirectoryAsync(polDir);
            await WorkspaceRepo.CreateDirectoryAsync(resDir);

            var bundleXml =
                "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?>\n" +
                "<SharedFlowBundle name=\"" + name + "\">\n" +
                "    <Description>" + name + "</Description>\n" +
                "    <Revision>1</Revision>\n" +
                "    <SharedFlows>\n" +
                "        <SharedFlow>default</SharedFlow>\n" +
                "    </SharedFlows>\n" +
                "</SharedFlowBundle>\n";

            await WorkspaceRepo.SaveFileAsync(
                System.IO.Path.Combine(sfDir, name + ".xml"), bundleXml);

            var sharedFlowXml =
                "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?>\n" +
                "<SharedFlow name=\"default\">\n" +
                "    <Description>Default shared flow</Description>\n" +
                "</SharedFlow>\n";

            await WorkspaceRepo.SaveFileAsync(
                System.IO.Path.Combine(resDir, "default.xml"), sharedFlowXml);

            _quickMessage = "✔ Shared Flow '" + name + "' criado.";
            _quickAddOpen = false;
            _tree = await WorkspaceRepo.LoadTreeAsync(_workspace);
            Toast.ShowSuccess("Shared Flow '" + name + "' criado.");
        }
        catch (Exception ex) { _quickMessage = "✘ " + ex.Message; _quickError = true; }
    }

    private async Task ConfirmQuickEnvironment()
    {
        if (string.IsNullOrWhiteSpace(_quickFileName) || _workspace is null) return;
        _quickMessage = string.Empty;
        _quickError   = false;
        try
        {
            var envName = _quickFileName.Trim();
            var envDir  = System.IO.Path.Combine(_workspace.RootPath, "environments", envName);
            await WorkspaceRepo.CreateDirectoryAsync(envDir);

            await WorkspaceRepo.SaveFileAsync(
                System.IO.Path.Combine(envDir, "deployments.json"),
                "{\n  \"proxies\": [],\n  \"sharedFlows\": []\n}");

            await WorkspaceRepo.SaveFileAsync(
                System.IO.Path.Combine(envDir, "flowhooks.json"),
                "{\n  \"PreProxyFlowHook\": {},\n  \"PostProxyFlowHook\": {},\n  \"PreTargetFlowHook\": {},\n  \"PostTargetFlowHook\": {}\n}");

            await WorkspaceRepo.SaveFileAsync(
                System.IO.Path.Combine(envDir, "targetservers.json"),
                "[]\n");

            _quickMessage = "✔ Environment '" + envName + "' criado.";
            _quickAddOpen = false;
            _deployEnv    = envName;
            _tree = await WorkspaceRepo.LoadTreeAsync(_workspace);
            Toast.ShowSuccess("Environment '" + envName + "' criado.");
        }
        catch (Exception ex) { _quickMessage = "✘ " + ex.Message; _quickError = true; }
    }

    private async Task CreateApiProxySkeletonAsync()
    {
        if (_workspace is null) return;

        var name = _quickFileName.Trim();
        if (string.IsNullOrWhiteSpace(name))
            throw new InvalidOperationException("Informe o nome da API.");

        var apiproxyDir  = System.IO.Path.Combine(_quickAddPath, name, "apiproxy");
        var policiesDir  = System.IO.Path.Combine(apiproxyDir, "policies");
        var proxiesDir   = System.IO.Path.Combine(apiproxyDir, "proxies");
        var resourcesDir = System.IO.Path.Combine(apiproxyDir, "resources");
        var targetsDir   = System.IO.Path.Combine(apiproxyDir, "targets");

        await WorkspaceRepo.CreateDirectoryAsync(apiproxyDir);
        await WorkspaceRepo.CreateDirectoryAsync(policiesDir);
        await WorkspaceRepo.CreateDirectoryAsync(proxiesDir);
        await WorkspaceRepo.CreateDirectoryAsync(resourcesDir);
        await WorkspaceRepo.CreateDirectoryAsync(targetsDir);

        var descriptorXml =
            "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?>\n" +
            "<APIProxy name=\"" + name + "\">\n" +
            "    <Description>" + name + "</Description>\n" +
            "    <Revision>1</Revision>\n" +
            "</APIProxy>\n";
        await WorkspaceRepo.SaveFileAsync(System.IO.Path.Combine(apiproxyDir, name + ".xml"), descriptorXml);

        var proxyEndpointXml =
            "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?>\n" +
            "<ProxyEndpoint name=\"default\">\n" +
            "    <Description>" + name + " proxy endpoint</Description>\n" +
            "    <HTTPProxyConnection>\n" +
            "        <BasePath>/" + name + "</BasePath>\n" +
            "        <VirtualHost>default</VirtualHost>\n" +
            "    </HTTPProxyConnection>\n" +
            "    <PreFlow name=\"PreFlow\">\n" +
            "        <Request/>\n" +
            "        <Response/>\n" +
            "    </PreFlow>\n" +
            "    <PostFlow name=\"PostFlow\">\n" +
            "        <Request/>\n" +
            "        <Response/>\n" +
            "    </PostFlow>\n" +
            "    <Flows/>\n" +
            "    <RouteRule name=\"default\">\n" +
            "        <TargetEndpoint>default</TargetEndpoint>\n" +
            "    </RouteRule>\n" +
            "</ProxyEndpoint>\n";
        await WorkspaceRepo.SaveFileAsync(System.IO.Path.Combine(proxiesDir, "default.xml"), proxyEndpointXml);

        var targetEndpointXml =
            "<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?>\n" +
            "<TargetEndpoint name=\"default\">\n" +
            "    <Description>Default target endpoint</Description>\n" +
            "    <PreFlow name=\"PreFlow\">\n" +
            "        <Request/>\n" +
            "        <Response/>\n" +
            "    </PreFlow>\n" +
            "    <PostFlow name=\"PostFlow\">\n" +
            "        <Request/>\n" +
            "        <Response/>\n" +
            "    </PostFlow>\n" +
            "    <Flows/>\n" +
            "    <HTTPTargetConnection>\n" +
            "        <URL>https://httpbin.org/anything</URL>\n" +
            "    </HTTPTargetConnection>\n" +
            "</TargetEndpoint>\n";
        await WorkspaceRepo.SaveFileAsync(System.IO.Path.Combine(targetsDir, "default.xml"), targetEndpointXml);

        await LoadFile(System.IO.Path.Combine(proxiesDir, "default.xml"));
        _quickAddOpen = false;
        _tree = await WorkspaceRepo.LoadTreeAsync(_workspace);
        Toast.ShowSuccess("API Proxy '" + name + "' criado com default.xml em proxies e targets.");
    }

    private async Task DeployProxy()
    {
        if (_workspace is null) return;
        await RunDeploy(() => DeployUseCase.ExecuteAsync(_workspace, _deployTarget, _deployEnv));
    }

    private async Task DeployFull()
    {
        if (_workspace is null) return;
        await RunDeploy(() => DeployUseCase.ExecuteFullAsync(_workspace, _deployEnv));
    }

    private async Task RunDeploy(Func<Task> action)
    {
        _deploying = true; _deployMessage = string.Empty; _deployError = false;
        try
        {
            await action();
            _deployMessage = "✔ Deploy realizado com sucesso!";
            Toast.ShowSuccess("Deploy concluído com sucesso!");
        }
        catch (Exception ex)
        {
            _deployMessage = "✘ Deploy falhou: " + ex.Message;
            _deployError = true;
            Toast.ShowError("Deploy falhou: " + ex.Message);
        }
        finally { _deploying = false; }
    }
}
