@page "/trace"
@using ApigeeLocalDev.Domain.Interfaces
@using ApigeeLocalDev.Domain.Entities
@inject IWorkspaceRepository WorkspaceRepo
@inject IProxyTraceService TraceService
@inject IConfiguration Config
@rendermode RenderMode.InteractiveServer

<div class="page-header">
    <h1>Trace</h1>
    <p class="page-subtitle">Capture e inspecione a execução de políticas em tempo real no Apigee Emulator.</p>
</div>

<div class="card" style="margin-bottom: var(--space-4); padding: var(--space-4);">
    <div style="display:flex; gap: var(--space-4); align-items: flex-end; flex-wrap: wrap;">
        <label class="input-label">
            Workspace
            <select class="input" @bind="_selectedWorkspace" @bind:after="OnWorkspaceChanged">
                <option value="">-- selecione --</option>
                @foreach (var ws in _workspaces)
                {
                    <option value="@ws.Name">@ws.Name</option>
                }
            </select>
        </label>

        @if (_proxies.Count > 0)
        {
            <label class="input-label">
                API Proxy
                <select class="input" @bind="_selectedProxy" @bind:after="OnProxyChanged">
                    <option value="">-- selecione --</option>
                    @foreach (var p in _proxies)
                    {
                        <option value="@p">@p</option>
                    }
                </select>
            </label>
        }
    </div>
</div>

<TraceViewer AvailableProxies="@_proxies" DefaultEnvironment="local" />

@code {
    private List<ApigeeWorkspace> _workspaces = [];
    private List<string>          _proxies    = [];
    private string _selectedWorkspace = string.Empty;
    private string _selectedProxy     = string.Empty;

    protected override void OnInitialized()
    {
        _workspaces = [.. WorkspaceRepo.ListAll()];
    }

    private void OnWorkspaceChanged()
    {
        _proxies       = [];
        _selectedProxy = string.Empty;
        var ws = _workspaces.FirstOrDefault(w => w.Name == _selectedWorkspace);
        if (ws is not null)
            _proxies = [.. WorkspaceRepo.ListApiProxies(ws)];

        TraceService.SetActiveProxy(
            _workspaces.FirstOrDefault(w => w.Name == _selectedWorkspace)?.RootPath ?? string.Empty,
            string.Empty);
    }

    private void OnProxyChanged()
    {
        var ws = _workspaces.FirstOrDefault(w => w.Name == _selectedWorkspace);
        if (ws is not null && !string.IsNullOrEmpty(_selectedProxy))
            TraceService.SetActiveProxy(ws.RootPath, _selectedProxy);
    }
}
