@page "/emulator"
@using ApigeeLocalDev.Domain.Interfaces
@inject IApigeeEmulatorClient EmulatorClient
@inject IConfiguration Config
@rendermode RenderMode.InteractiveServer

<div class="page-header">
    <h1>Emulator</h1>
    <p class="page-subtitle">Gerencie o container do Apigee Emulator e realize deploys rápidos.</p>
</div>

<!-- CONTAINER MANAGEMENT -->
<div class="card emulator-manage">
    <h3>Container Docker</h3>
    <p class="help-text">Escolha a imagem e suba/derrube o container local do Apigee Emulator.</p>

    <div class="form-grid">
        <label>
            Imagem Docker
            <input class="input" @bind="_image" list="emulator-images" placeholder="gcr.io/apigee-release/hybrid/apigee-emulator:latest" />
        </label>
        <div class="emulator-actions">
            <button class="btn btn-primary" @onclick="StartContainer" disabled="@_dockerBusy">&#9654; Start</button>
            <button class="btn btn-ghost btn-sm btn-danger" @onclick="StopContainer" disabled="@_dockerBusy">&#9632; Stop</button>
        </div>
    </div>

    <datalist id="emulator-images">
        @foreach (var img in _images)
        {
            <option value="@img"></option>
        }
    </datalist>

    @if (!string.IsNullOrEmpty(_dockerMessage))
    {
        <p class="mt-2 @(_dockerError ? "error-text" : "success-text")">@_dockerMessage</p>
    }
</div>

<!-- STATUS -->
<div class="card emulator-status">
    <div class="status-row">
        <div class="status-label">
            <span class="status-dot @(_alive ? "dot-green" : "dot-red")"></span>
            <span>@(_checking ? "Verificando..." : (_alive ? "Emulator online" : "Emulator offline"))</span>
        </div>
        <button class="btn btn-ghost btn-sm" @onclick="Check" disabled="@_checking">&#8635; Refresh</button>
    </div>

    @if (_statusError is not null)
    {
        <p class="help-text error-text">@_statusError</p>
    }
    else
    {
        <p class="help-text">
            Base URL: <code>@_baseUrl</code> &mdash;
            certifique-se de que o container Docker está rodando.
        </p>
    }
</div>

<!-- QUICK DEPLOY -->
<div class="card">
    <h3>Quick Deploy</h3>
    <p class="help-text">Informe o caminho de um ZIP e o ambiente alvo para fazer deploy direto no emulator.</p>

    <div class="form-grid">
        <label>
            ZIP file path
            <input class="input" @bind="_zipPath" placeholder="C:/tmp/my-proxy.zip" />
        </label>
        <label>
            Environment
            <input class="input" @bind="_env" placeholder="local" />
        </label>
    </div>

    <button class="btn btn-primary" @onclick="QuickDeploy" disabled="@_deployDisabled">
        @(_deploying ? "Deploying..." : "Deploy ZIP")
    </button>

    @if (!string.IsNullOrEmpty(_message))
    {
        <p class="mt-2 @(_isError ? "error-text" : "success-text")">@_message</p>
    }
</div>

@code {
    private bool   _alive;
    private bool   _checking;
    private string _baseUrl      = string.Empty;
    private string? _statusError;

    private string _zipPath      = string.Empty;
    private string _env          = "local";
    private bool   _deploying;
    private string _message      = string.Empty;
    private bool   _isError;

    private string        _image        = string.Empty;
    private List<string>  _images       = new();
    private bool          _dockerBusy;
    private string        _dockerMessage = string.Empty;
    private bool          _dockerError;

    private bool _deployDisabled => _deploying || !_alive;

    protected override async Task OnInitializedAsync()
    {
        _baseUrl = Config["ApigeeEmulator:BaseUrl"] ?? "http://localhost:8080";
        _image   = Config["ApigeeEmulator:Image"] ?? "gcr.io/apigee-release/hybrid/apigee-emulator:latest";
        await LoadImages();
        await Check();
    }

    private async Task LoadImages()
    {
        try
        {
            var list = await EmulatorClient.ListImagesAsync();
            _images   = [.. list];
            if (string.IsNullOrWhiteSpace(_image))
                _image = _images.FirstOrDefault(
                             i => i.Contains("apigee", StringComparison.OrdinalIgnoreCase))
                         ?? "gcr.io/apigee-release/hybrid/apigee-emulator:latest";
        }
        catch (Exception ex)
        {
            _dockerMessage = "Não foi possível listar imagens: " + ex.Message;
            _dockerError   = true;
        }
    }

    private async Task StartContainer()
    {
        if (string.IsNullOrWhiteSpace(_image))
        {
            _dockerMessage = "Informe a imagem Docker.";
            _dockerError   = true;
            return;
        }

        _dockerBusy    = true;
        _dockerMessage = string.Empty;
        _dockerError   = false;
        try
        {
            await EmulatorClient.StartContainerAsync(_image);
            _dockerMessage = "\u2714 Container iniciado.";
            await Check();
        }
        catch (Exception ex)
        {
            _dockerMessage = "\u2718 Erro ao iniciar: " + ex.Message;
            _dockerError   = true;
        }
        finally { _dockerBusy = false; }
    }

    private async Task StopContainer()
    {
        _dockerBusy    = true;
        _dockerMessage = string.Empty;
        _dockerError   = false;
        try
        {
            await EmulatorClient.StopContainerAsync();
            _dockerMessage = "\u2714 Container parado.";
            await Check();
        }
        catch (Exception ex)
        {
            _dockerMessage = "\u2718 Erro ao parar: " + ex.Message;
            _dockerError   = true;
        }
        finally { _dockerBusy = false; }
    }

    private async Task Check()
    {
        _checking    = true;
        _statusError = null;
        try
        {
            _alive = await EmulatorClient.IsAliveAsync();
        }
        catch (Exception ex)
        {
            _alive       = false;
            _statusError = "Não foi possível conectar: " + ex.Message;
        }
        finally
        {
            _checking = false;
        }
    }

    private async Task QuickDeploy()
    {
        if (string.IsNullOrWhiteSpace(_zipPath)) { _message = "Informe o caminho do ZIP."; _isError = true; return; }

        _deploying = true;
        _message   = string.Empty;
        _isError   = false;
        try
        {
            await EmulatorClient.DeployBundleAsync(_env, _zipPath);
            _message = "\u2714 Deploy realizado com sucesso!";
        }
        catch (Exception ex)
        {
            _message = "\u2718 Erro: " + ex.Message;
            _isError = true;
        }
        finally { _deploying = false; }
    }
}
