@inherits LayoutComponentBase

<div class="app-shell">
    <aside class="sidebar">
        <div class="sidebar-logo">
            <svg
                viewBox="0 0 32 32"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                width="26"
                height="26"
                aria-label="Apigee Local Dev">
                <rect width="32" height="32" rx="7" fill="#4f98a3" />
                <path d="M8 24 L16 8 L24 24" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none" />
                <path d="M10.5 19h11" stroke="white" stroke-width="2" stroke-linecap="round" />
            </svg>
            <span>Apigee Local Dev</span>
        </div>
        <nav class="sidebar-nav">
            <NavLink href="/" Match="NavLinkMatch.All" class="nav-item">
                <i data-lucide="layout-grid" class="nav-icon"></i>
                <span>Workspaces</span>
            </NavLink>

            <NavLink href="/emulator" class="nav-item">
                <i data-lucide="terminal" class="nav-icon"></i>
                <span>Emulator</span>
            </NavLink>
            <NavLink href="/environment-config" class="nav-item">
                <i data-lucide="settings" class="nav-icon"></i>
                <span>Env Config (KVMs)</span>
            </NavLink>
            <NavLink href="/trace" class="nav-item">
                <i data-lucide="radio" class="nav-icon"></i>
                <span>Policy Trace</span>
            </NavLink>
        </nav>
        <div class="sidebar-footer">
            <span class="sidebar-version">v1.0.0</span>
        </div>
    </aside>
    <main class="main-content">
        @Body
    </main>
</div>

<ToastContainer />
