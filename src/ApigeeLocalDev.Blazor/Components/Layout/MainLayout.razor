@inherits LayoutComponentBase

<div class="app-shell">
    <aside class="sidebar">
        <div class="sidebar-logo">
            <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" width="28" height="28" aria-label="Apigee Local Dev">
                <rect width="32" height="32" rx="6" fill="#01696f"/>
                <path d="M8 24 L16 8 L24 24" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                <path d="M10.5 19h11" stroke="white" stroke-width="2" stroke-linecap="round"/>
            </svg>
            <span>Apigee Local Dev</span>
        </div>
        <nav class="sidebar-nav">
            <NavLink href="/" Match="NavLinkMatch.All" class="nav-item">
                <span class="nav-icon">&#9632;</span> Workspaces
            </NavLink>
            <NavLink href="/templates" class="nav-item">
                <span class="nav-icon">&#9670;</span> Policy Templates
            </NavLink>
            <NavLink href="/emulator" class="nav-item">
                <span class="nav-icon">&#9654;</span> Emulator
            </NavLink>
        </nav>
    </aside>
    <main class="main-content">
        @Body
    </main>
</div>
