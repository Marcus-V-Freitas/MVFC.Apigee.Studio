{
  "WorkspacesRoot": "C:/Users/YOUR_USER/apigee-workspaces",
  "ApigeeEmulator": {
    "BaseUrl": "http://localhost:8080",
    "Image": "gcr.io/apigee-release/hybrid/apigee-emulator:1.10.0"
  },
  "ApigeeTemplates": {
    "DefaultTargetUrl": "https://httpbin.org/anything"
  },
  "ExternalTools": {
    "LintTool": "apigeelint"
  },
  "EmulatorRuntime": {
    "BaseUrl": "http://localhost:8998"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}