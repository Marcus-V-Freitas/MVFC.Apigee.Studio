@using System.Text.Json.Nodes
@using MVFC.Apigee.Studio.Domain.Interfaces
@inject IApigeeEmulatorClient EmulatorClient
@inject IJSRuntime JS

<div class="card mt-4 emulator-state-viewer">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
        <h3>Emulator Live State</h3>
        <button class="btn btn-ghost btn-sm" @onclick="LoadData" disabled="@_loading">
            <i data-lucide="refresh-cw" class="@(_loading ? "spin" : "")"></i> Refresh
        </button>
    </div>

    <div class="test-resources-tabs mb-3">
        <button class="tab-btn @(_activeTab == "deployments" ? "active" : "")" @onclick='() => _activeTab = "deployments"'>Deployments</button>
        <button class="tab-btn @(_activeTab == "analytics" ? "active" : "")" @onclick='() => _activeTab = "analytics"'>Analytics</button>
        <button class="tab-btn @(_activeTab == "products" ? "active" : "")" @onclick='() => _activeTab = "products"'>Products</button>
        <button class="tab-btn @(_activeTab == "developers" ? "active" : "")" @onclick='() => _activeTab = "developers"'>Developers</button>
        <button class="tab-btn @(_activeTab == "maps" ? "active" : "")" @onclick='() => _activeTab = "maps"'>KVMs</button>
    </div>

    <div class="card-body">
        @if (_loading)
        {
            <div class="empty-mini-state">Carregando dados do emulador...</div>
        }
        else if (!string.IsNullOrEmpty(_error))
        {
            <div class="empty-mini-state error-text">@_error</div>
        }
        else
        {
            @if (_activeTab == "deployments")
            {
                if (_deployments is JsonArray dArr && dArr.Count > 0)
                {
                    <table class="table" style="width: 100%; border-collapse: collapse;">
                        <thead>
                            <tr style="border-bottom: 1px solid var(--color-border); text-align: left;">
                                <th style="padding: 8px;">Environment</th>
                                <th style="padding: 8px;">Name</th>
                                <th style="padding: 8px;">Revision</th>
                                <th style="padding: 8px;">Base Path</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var dep in dArr)
                            {
                                <tr style="border-bottom: 1px solid var(--color-border);">
                                    <td style="padding: 8px;">@dep?["environment"]?.ToString()</td>
                                    <td style="padding: 8px;"><strong>@dep?["name"]?.ToString()</strong></td>
                                    <td style="padding: 8px;">@dep?["revision"]?.ToString()</td>
                                    <td style="padding: 8px;"><code>@dep?["basePath"]?.ToString()</code></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty-mini-state">Nenhum deployment encontrado.</div>
                }
            }
            else if (_activeTab == "analytics")
            {
                if (_analytics is null || _analytics.Count == 0) { <div class="empty-mini-state">Sem dados de analytics.</div> }
                else
                {
                    <div class="analytics-container" style="height: 280px; margin-bottom: 16px; background: #0d1117; padding: 16px; border-radius: 8px; border: 1px solid var(--color-border);">
                        <canvas id="analyticsChart"></canvas>
                    </div>
                    <details>
                        <summary style="font-size: 11px; color: var(--color-text-muted); cursor: pointer; margin-bottom: 8px; user-select: none;">&#9656; Ver dados brutos (JSON)</summary>
                        <pre class="json-preview">@_analytics.ToJsonString(new System.Text.Json.JsonSerializerOptions { WriteIndented = true })</pre>
                    </details>
                }
            }
            else if (_activeTab == "products")
            {
                if (_products is null || _products.Count == 0) { <div class="empty-mini-state">Nenhum produto no emulador.</div> }
                else
                {
                    <table class="table" style="width: 100%; border-collapse: collapse;">
                        <thead>
                            <tr style="border-bottom: 1px solid var(--color-border); text-align: left;">
                                <th style="padding: 8px;">Name</th>
                                <th style="padding: 8px;">Display Name</th>
                                <th style="padding: 8px;">Environments</th>
                                <th style="padding: 8px;">Proxies</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var prod in _products)
                            {
                                <tr style="border-bottom: 1px solid var(--color-border);">
                                    <td style="padding: 8px;"><strong>@prod?["name"]?.ToString()</strong></td>
                                    <td style="padding: 8px;">@prod?["displayName"]?.ToString()</td>
                                    <td style="padding: 8px;">
                                        <div style="display: flex; gap: 4px; flex-wrap: wrap;">
                                        @foreach (var env in prod?["environments"]?.AsArray() ?? new JsonArray())
                                        {
                                            <span style="background: var(--color-bg); padding: 2px 6px; border-radius: 4px; font-size: 11px; border: 1px solid var(--color-border);">@env?.ToString()</span>
                                        }
                                        </div>
                                    </td>
                                    <td style="padding: 8px;">
                                        <div style="display: flex; gap: 4px; flex-wrap: wrap;">
                                        @foreach (var pxy in prod?["proxies"]?.AsArray() ?? new JsonArray())
                                        {
                                            <span style="background: var(--color-bg); padding: 2px 6px; border-radius: 4px; font-size: 11px; border: 1px solid var(--color-border);">@pxy?.ToString()</span>
                                        }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            }
            else if (_activeTab == "developers")
            {
                if (_developers is null || _developers.Count == 0) { <div class="empty-mini-state">Nenhum desenvolvedor no emulador.</div> }
                else
                {
                    <table class="table" style="width: 100%; border-collapse: collapse;">
                        <thead>
                            <tr style="border-bottom: 1px solid var(--color-border); text-align: left;">
                                <th style="padding: 8px;">Email</th>
                                <th style="padding: 8px;">Name</th>
                                <th style="padding: 8px;">User Name</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var dev in _developers)
                            {
                                <tr style="border-bottom: 1px solid var(--color-border);">
                                    <td style="padding: 8px;"><strong>@dev?["email"]?.ToString()</strong></td>
                                    <td style="padding: 8px;">@dev?["firstName"]?.ToString() @dev?["lastName"]?.ToString()</td>
                                    <td style="padding: 8px;">@dev?["userName"]?.ToString()</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            }
            else if (_activeTab == "maps")
            {
                if (_maps is null || _maps.Count == 0) { <div class="empty-mini-state">Nenhum KVM no emulador.</div> }
                else
                {
                    <div class="kvm-list" style="display: flex; flex-direction: column; gap: var(--space-3);">
                        @foreach (var map in _maps)
                        {
                            <div style="background: var(--color-bg-alt); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-2);">
                                <div style="border-bottom: 1px solid var(--color-border); padding-bottom: 8px; margin-bottom: 8px;">
                                    <strong>@map?["name"]?.ToString()</strong>
                                </div>
                                <table class="table" style="width: 100%; border-collapse: collapse; font-size: var(--text-sm);">
                                    <thead><tr style="text-align: left;"><th style="padding: 4px;">Key</th><th style="padding: 4px;">Value</th></tr></thead>
                                    <tbody>
                                        @foreach (var entry in map?["entry"]?.AsArray() ?? new JsonArray())
                                        {
                                            <tr>
                                                <td style="padding: 4px; width: 30%;"><code>@entry?["name"]?.ToString()</code></td>
                                                <td style="padding: 4px;">@entry?["value"]?.ToString()</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                }
            }
        }
    </div>
</div>

<style>
    .emulator-state-viewer .test-resources-tabs {
        display: flex;
        gap: var(--space-1);
        background: var(--color-bg-alt);
        padding: 2px;
        border-radius: var(--radius-md);
        margin: 0 var(--space-3) var(--space-3) var(--space-3);
    }
    .emulator-state-viewer .tab-btn {
        border: none;
        background: transparent;
        color: var(--color-text-muted);
        padding: var(--space-1) var(--space-3);
        font-size: var(--text-xs);
        font-weight: 500;
        cursor: pointer;
        border-radius: var(--radius-sm);
        transition: all 0.2s;
    }
    .emulator-state-viewer .tab-btn.active {
        background: var(--color-bg);
        color: var(--color-text);
        box-shadow: var(--shadow-sm);
    }
    .json-preview {
        background: var(--color-bg-alt);
        padding: var(--space-3);
        border-radius: var(--radius-md);
        color: var(--color-text);
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        max-height: 400px;
        overflow-y: auto;
        white-space: pre-wrap;
        word-break: break-all;
    }
</style>

@code {
    private string _activeTab = "deployments";
    private bool _loading;
    private string? _error;

    private JsonNode? _deployments;
    private JsonArray? _analytics;
    private JsonArray? _products;
    private JsonArray? _developers;
    private JsonArray? _maps;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_activeTab == "analytics" && _analytics != null && _analytics.Count > 0)
        {
            try 
            {
                await JS.InvokeVoidAsync("renderAnalyticsChart", "analyticsChart", _analytics);
            }
            catch { /* Ignore JS errors during fast switching */ }
        }
    }

    private async Task LoadData()
    {
        _loading = true;
        _error = null;
        StateHasChanged();
        try
        {
            _deployments = await EmulatorClient.GetDeploymentsAsync();
            _analytics = await EmulatorClient.GetAnalyticsAsync();
            _products = await EmulatorClient.GetProductsAsync();
            _developers = await EmulatorClient.GetDevelopersAsync();
            _maps = await EmulatorClient.GetKeyValueMapsAsync();
        }
        catch (Exception ex)
        {
            _error = "Erro ao buscar dados do emulador: " + ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
