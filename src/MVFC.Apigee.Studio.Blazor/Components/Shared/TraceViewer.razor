<div class="trace-viewer">
    @if (!Transactions.Any())
    {
        <div class="trace-empty">
            <i data-lucide="radio" class="icon-xl"></i>
            <p>Nenhuma transação capturada ainda.<br/>Faça uma requisição ao proxy enquanto o trace estiver ativo.</p>
        </div>
    }
    else
    {
        <div class="trace-list">
            @foreach (var tx in Transactions)
            {
                var isExpanded  = _expanded.Contains(tx.MessageId);
                var statusClass = GetStatusClass(tx.ResponseCode);
                var methodClass = tx.RequestMethod switch
                {
                    "GET"    => "method-get",
                    "POST"   => "method-post",
                    "PUT"    => "method-put",
                    "DELETE" => "method-delete",
                    "PATCH"  => "method-patch",
                    _        => "method-other"
                };

                <div class="trace-tx @(isExpanded ? "trace-tx--open" : "")">

                    <button @key="isExpanded" class="trace-tx-header" @onclick="() => Toggle(tx.MessageId)">
                        <span class="tx-method @methodClass">@tx.RequestMethod</span>
                        <span class="tx-uri">@tx.RequestUri</span>
                        <div class="tx-meta">
                            <span class="tx-status-badge @statusClass">@tx.ResponseCode</span>
                            @if (tx.TotalTimeMs > 0)
                            {
                                <span class="tx-time">
                                    <i data-lucide="timer" class="icon-xs"></i>
                                    @tx.TotalTimeMs ms
                                </span>
                            }
                            <span class="tx-steps">@tx.Points.Count step(s)</span>
                        </div>
                        <i data-lucide="@(isExpanded ? "chevron-up" : "chevron-down")" class="tx-chevron"></i>
                    </button>

                    @if (isExpanded)
                    {
                        var groups = GroupPointsByPhase(tx.Points);
                        var selectedPt = GetSelectedPoint(tx.MessageId);

                        <div class="trace-flow-container">
                            @* ── Horizontal Flow Pipeline ── *@
                            <div class="trace-pipeline">
                                <div class="pipeline-scroll">
                                    @foreach (var group in groups)
                                    {
                                        var phaseClr  = PhaseColorClass(group.PhaseName);
                                        var phaseIcon = PhaseIcon(group.PhaseName);
                                        var phaseLabel = PhaseDisplayName(group.PhaseName);

                                        <div class="pipeline-phase @phaseClr">
                                            <div class="pipeline-phase-header">
                                                <i data-lucide="@phaseIcon" class="pipeline-phase-icon"></i>
                                                <span class="pipeline-phase-name">@phaseLabel</span>
                                            </div>

                                            <div class="pipeline-steps">
                                                @foreach (var pt in group.Points)
                                                {
                                                    var isSelected = selectedPt == pt;
                                                    var stepClass = pt.PointType switch
                                                    {
                                                        "Condition" => "step-condition",
                                                        "Execution" => pt.HasError ? "step-error" : "step-execution",
                                                        _           => "step-state"
                                                    };
                                                    var stepIcon = pt.PointType switch
                                                    {
                                                        "Condition" => pt.Description?.Equals("true", StringComparison.OrdinalIgnoreCase) == true
                                                            ? "check-circle-2" : "x-circle",
                                                        "Execution" => pt.HasError ? "alert-circle" : "circle-dot",
                                                        _           => "chevrons-right"
                                                    };

                                                    <button @key="pt" class="pipeline-step @stepClass @(isSelected ? "step-active" : "")"
                                                            @onclick="() => SelectPoint(tx.MessageId, pt)"
                                                            @onclick:stopPropagation="true"
                                                            title="@pt.PolicyName">
                                                        <i data-lucide="@stepIcon" class="step-icon"></i>
                                                        <span class="step-name">@TruncateName(pt.PolicyName)</span>
                                                    </button>
                                                }
                                            </div>
                                        </div>

                                        @if (group != groups[^1])
                                        {
                                            <div class="pipeline-connector">
                                                <i data-lucide="chevron-right" class="connector-arrow"></i>
                                            </div>
                                        }
                                    }
                                </div>
                            </div>

                            @* ── Details Panel ── *@
                            @if (selectedPt is not null)
                            {
                                <div class="trace-details">
                                    <div class="trace-details-header">
                                        <div @key="selectedPt" class="trace-details-title">
                                            @{
                                                var detailIcon = selectedPt.PointType switch
                                                {
                                                    "Condition" => selectedPt.Description?.Equals("true", StringComparison.OrdinalIgnoreCase) == true
                                                        ? "check-circle-2" : "x-circle",
                                                    "Execution" => selectedPt.HasError ? "alert-circle" : "circle-dot",
                                                    _ => "chevrons-right"
                                                };
                                                var detailTypeClass = selectedPt.PointType switch
                                                {
                                                    "Condition" => selectedPt.Description?.Equals("true", StringComparison.OrdinalIgnoreCase) == true
                                                        ? "detail-cond-pass" : "detail-cond-fail",
                                                    "Execution" => selectedPt.HasError ? "detail-error" : "detail-exec",
                                                    _ => "detail-state"
                                                };
                                            }
                                            <i data-lucide="@detailIcon" class="detail-icon @detailTypeClass"></i>
                                            <span class="detail-name">@selectedPt.PolicyName</span>
                                            <span class="detail-type-badge">@selectedPt.PointType</span>
                                        </div>
                                        <button class="btn btn-ghost btn-sm" @onclick="() => ClearSelection(tx.MessageId)"
                                                @onclick:stopPropagation="true">
                                            <i data-lucide="x" class="icon-xs"></i>
                                        </button>
                                    </div>

                                    <div class="trace-details-body">
                                        @* ── Summary Info ── *@
                                        <div class="detail-section">
                                            <div class="detail-props">
                                                @if (!string.IsNullOrWhiteSpace(selectedPt.Phase))
                                                {
                                                    <div class="detail-prop">
                                                        <span class="prop-key">Phase</span>
                                                        <span class="prop-val">@selectedPt.Phase</span>
                                                    </div>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(selectedPt.Description))
                                                {
                                                    <div class="detail-prop">
                                                        <span class="prop-key">Description</span>
                                                        <span class="prop-val">@selectedPt.Description</span>
                                                    </div>
                                                }
                                                @if (selectedPt.ElapsedTimeMs > 0)
                                                {
                                                    <div class="detail-prop">
                                                        <span class="prop-key">Elapsed Time</span>
                                                        <span class="prop-val prop-val-time">@selectedPt.ElapsedTimeMs ms</span>
                                                    </div>
                                                }
                                                @if (selectedPt.HasError)
                                                {
                                                    <div class="detail-prop detail-prop-error">
                                                        <span class="prop-key">Status</span>
                                                        <span class="prop-val prop-val-error">
                                                            <i data-lucide="alert-triangle" class="icon-xs"></i>
                                                            Error
                                                        </span>
                                                    </div>
                                                }
                                                @if (selectedPt.PointType == "Condition")
                                                {
                                                    var condResult = selectedPt.Description?.Equals("true", StringComparison.OrdinalIgnoreCase) == true;
                                                    <div class="detail-prop">
                                                        <span class="prop-key">Result</span>
                                                        <span class="prop-val @(condResult ? "prop-val-pass" : "prop-val-fail")">
                                                            @(condResult ? "✓ true" : "✗ false")
                                                        </span>
                                                    </div>
                                                }
                                            </div>
                                        </div>

                                        @* ── Headers & Variables ── *@
                                        @if (selectedPt.Variables.Any())
                                        {
                                            var reqHeaders = selectedPt.Variables.Where(v => v.Key.StartsWith("request.header.", StringComparison.OrdinalIgnoreCase)).ToList();
                                            var resHeaders = selectedPt.Variables.Where(v => v.Key.StartsWith("response.header.", StringComparison.OrdinalIgnoreCase)).ToList();
                                            var msgHeaders = selectedPt.Variables.Where(v => v.Key.StartsWith("message.header.", StringComparison.OrdinalIgnoreCase)).ToList();
                                            var otherVars  = selectedPt.Variables.Where(v => !v.Key.StartsWith("request.header.") 
                                                                                          && !v.Key.StartsWith("response.header.")
                                                                                          && !v.Key.StartsWith("message.header.")).ToList();

                                            @if (reqHeaders.Any() || resHeaders.Any() || msgHeaders.Any())
                                            {
                                                if (reqHeaders.Any())
                                                {
                                                    <div class="detail-section">
                                                        <div class="detail-section-header">
                                                            <i data-lucide="log-in" class="icon-xs"></i>
                                                            <span>Request Headers (@reqHeaders.Count)</span>
                                                        </div>
                                                        <div class="detail-vars">
                                                            @foreach (var kv in reqHeaders)
                                                            {
                                                                var headerName = kv.Key.Substring(15); @* len("request.header.") *@
                                                                <div class="var-row">
                                                                    <span class="var-key">@headerName</span>
                                                                    <span class="var-val">@kv.Value</span>
                                                                </div>
                                                            }
                                                        </div>
                                                    </div>
                                                }
                                                if (resHeaders.Any())
                                                {
                                                    <div class="detail-section">
                                                        <div class="detail-section-header">
                                                            <i data-lucide="log-out" class="icon-xs"></i>
                                                            <span>Response Headers (@resHeaders.Count)</span>
                                                        </div>
                                                        <div class="detail-vars">
                                                            @foreach (var kv in resHeaders)
                                                            {
                                                                var headerName = kv.Key.Substring(16); @* len("response.header.") *@
                                                                <div class="var-row">
                                                                    <span class="var-key">@headerName</span>
                                                                    <span class="var-val">@kv.Value</span>
                                                                </div>
                                                            }
                                                        </div>
                                                    </div>
                                                }
                                                if (msgHeaders.Any())
                                                {
                                                    <div class="detail-section">
                                                        <div class="detail-section-header">
                                                            <i data-lucide="message-square" class="icon-xs"></i>
                                                            <span>Message Headers (@msgHeaders.Count)</span>
                                                        </div>
                                                        <div class="detail-vars">
                                                            @foreach (var kv in msgHeaders)
                                                            {
                                                                var headerName = kv.Key.Substring(15); @* len("message.header.") *@
                                                                <div class="var-row">
                                                                    <span class="var-key">@headerName</span>
                                                                    <span class="var-val">@kv.Value</span>
                                                                </div>
                                                            }
                                                        </div>
                                                    </div>
                                                }
                                            }

                                            if (otherVars.Any())
                                            {
                                                <div class="detail-section">
                                                    <div class="detail-section-header">
                                                        <i data-lucide="braces" class="icon-xs"></i>
                                                        <span>Properties & Variables (@otherVars.Count)</span>
                                                    </div>
                                                    <div class="detail-vars">
                                                        @foreach (var kv in otherVars)
                                                        {
                                                            <div class="var-row">
                                                                <span class="var-key">@kv.Key</span>
                                                                <span class="var-val">@kv.Value</span>
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                        }
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="trace-details trace-details-hint">
                                    <i data-lucide="mouse-pointer-click" class="icon-md"></i>
                                    <span>Clique em um step no pipeline para ver os detalhes.</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>