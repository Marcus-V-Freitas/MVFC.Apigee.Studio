@page "/environment-config"
@rendermode RenderMode.InteractiveServer

<div class="page-header">
    <h1>Environment Config</h1>
    <p class="page-subtitle">
        Gerencie KVMs, Caches e Target Servers (JSONs) para o seu Apigee Emulator.
    </p>
</div>

<div class="card mb-4">
    <div class="config-header-row">
        <div class="form-field flex-1">
            <label>Workspace</label>
            <select class="input" @bind="_selectedWorkspaceName" @bind:after="OnWorkspaceChanged">
                <option value="">-- Selecione --</option>
                @foreach (var name in _workspaces.Select(w => w.Name))
                {
                    <option value="@name">@name</option>
                }
            </select>
        </div>

        <div class="form-field flex-1">
            <label>Environment</label>
            <select class="input" @bind="_selectedEnvironment" @bind:after="OnEnvironmentChanged" disabled="@WorkspaceNotSelected">
                <option value="">-- Selecione --</option>
                @foreach (var env in _environments)
                {
                    <option value="@env">@env</option>
                }
            </select>
        </div>

        @if (_workspace != null)
        {
            <div class="form-field flex-0">
                <label class="hidden-label">New</label>
                <div class="new-env-form">
                    <input class="input new-env-input" placeholder="Novo env..." @bind="_newEnvName" />
                    <button class="btn btn-primary" @onclick="CreateEnvironment" disabled="@string.IsNullOrWhiteSpace(_newEnvName)">
                        Criar
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@if (_workspace != null && !string.IsNullOrEmpty(_selectedEnvironment))
{
    <div class="config-grid">

        <!-- KVMs -->
        <div class="card">
            <div class="card-title-row">
                <h3>KVMs (maps.json)</h3>
                <button class="btn btn-ghost btn-sm" @onclick="LoadKvm">Refresh</button>
            </div>
            <textarea class="input mt-2 config-textarea" @bind="_kvmJson"></textarea>
            <button class="btn btn-primary mt-2" @onclick="SaveKvm">Save KVMs</button>
            @if (_kvmIsDirty)
            {
                <span class="dirty-hint">Changes not saved</span>
            }
        </div>

        <!-- Caches -->
        <div class="card">
            <div class="card-title-row">
                <h3>Caches (caches.json)</h3>
                <button class="btn btn-ghost btn-sm" @onclick="LoadCaches">Refresh</button>
            </div>
            <textarea class="input mt-2 config-textarea" @bind="_cachesJson"></textarea>
            <button class="btn btn-primary mt-2" @onclick="SaveCaches">Save Caches</button>
            @if (_cachesIsDirty)
            {
                <span class="dirty-hint">Changes not saved</span>
            }
        </div>

        <!-- Target Servers -->
        <div class="card full-width">
            <div class="card-title-row">
                <h3>Target Servers (targetservers.json)</h3>
                <button class="btn btn-ghost btn-sm" @onclick="LoadTargetServers">Refresh</button>
            </div>
            <textarea class="input mt-2 config-textarea" @bind="_targetServersJson"></textarea>
            <button class="btn btn-primary mt-2" @onclick="SaveTargetServers">Save Target Servers</button>
            @if (_targetIsDirty)
            {
                <span class="dirty-hint">Changes not saved</span>
            }
        </div>

    </div>
}
