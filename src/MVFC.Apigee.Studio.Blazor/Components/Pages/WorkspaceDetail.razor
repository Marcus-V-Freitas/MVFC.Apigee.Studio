@page "/workspace/{WorkspaceName}"

<div style="display: flex; align-items: center; gap: var(--space-3); margin-bottom: var(--space-4);">
    <a href="/" class="btn-icon" title="Voltar aos Workspaces" style="text-decoration: none;">
        <i data-lucide="arrow-left"></i>
    </a>
    <h1 style="margin: 0;">@WorkspaceName</h1>
</div>

@if (_workspace is null)
{
    <p class="error-text">Workspace não encontrado.</p>
}
else
{
    <div class="workspace-detail">
        <FileExplorer Tree="_tree" 
                      SelectedFilePath="@EditorState.ActiveTab?.FullPath"
                      @bind-SearchQuery="_searchQuery"
                      OnFileSelected="LoadFile"
                      OnQuickAdd="OpenQuickAddModal"
                      OnContextMenu="HandleContextMenu"
                      OnNewItem="OpenNewItemDialog" />

        <section class="file-editor">
            @if (EditorState.OpenTabs.Any())
            {
                <EditorTabs Tabs="EditorState.OpenTabs" 
                            ActiveTab="EditorState.ActiveTab"
                            OnTabSwitch="SwitchTab"
                            OnTabClose="CloseTab"
                            OnCloseOtherTabs="CloseOtherTabs"
                            OnCloseAllTabs="CloseAllTabs" />

                @if (EditorState.ActiveTab is not null)
                {
                    <div class="editor-header">
                        <div class="editor-header-left">
                            <span class="editor-filename">@EditorState.ActiveTab.FileName</span>
                            <span class="editor-lang-badge">@DetectLanguage()</span>
                        </div>
                        <div class="editor-header-actions">
                            <button class="btn btn-ghost btn-sm" title="Format (Alt+Shift+F)" @onclick="FormatDocument">✨ <span>Format</span></button>
                            <button class="btn btn-ghost btn-sm btn-danger" @onclick="DeleteSelectedFile">🗑️ <span>Delete</span></button>
                            <button class="btn btn-primary btn-sm" @onclick="SaveFile" disabled="@_saving" title="Ctrl+S">
                                @if (_saving)
                                {
                                    <span>Salvando...</span>
                                }
                                else
                                {
                                    <span>💾 Save</span>
                                    <kbd class="kbd-hint">Ctrl+S</kbd>
                                }
                            </button>
                        </div>
                    </div>
                    <MonacoEditor @key="EditorState.ActiveTab.FullPath"
                                 @ref="_editor"
                                 Id="@EditorId"
                                 CssClass="monaco-container"
                                 InitialContent="@EditorState.ActiveTab.Content"
                                 FilePath="@EditorState.ActiveTab.FullPath"
                                 OnSave="SaveFile" />
                }
            }
            else
            {
                <div class="empty-state">Selecione ou crie um arquivo para editar.</div>
            }
        </section>
    </div>

    <QuickAddDrawer IsOpen="_quickAddOpen"
                   Category="@_quickAddCategory"
                   BasePath="@_quickAddPath"
                   Workspace="_workspace"
                   OnClose="CloseQuickAdd"
                   OnItemCreated="OnItemCreated" />

    <DeploymentPanel Workspace="_workspace" />

    @if (_showNewItem)
    {
        <div class="modal-backdrop new-item-backdrop" @onclick="() => _showNewItem = false">
            <div class="card new-item-modal" @onclick:stopPropagation>
                <div class="card-header">
                    <h3 class="card-title">@(_newItemIsDir ? "Nova Pasta" : "Novo Arquivo")</h3>
                </div>
                <div class="card-body">
                    @if (_targetDirContext is null && _tree is not null)
                    {
                        <div class="form-field" style="margin-bottom: var(--space-3);">
                            <label style="font-size: var(--text-xs); font-weight: 600; color: var(--color-text-muted); text-transform: uppercase;">Destino</label>
                            <select class="input new-item-input" @bind="_selectedNewItemPath">
                                <option value="@_workspace!.RootPath">Raiz do Workspace</option>
                                @foreach (var dir in CollectDirectories(_tree))
                                {
                                    <option value="@dir.FullPath">@dir.RelativePath</option>
                                }
                            </select>
                        </div>
                    }
                    <input class="input new-item-input" @bind="_newItemName"
                           placeholder="@NewItemPlaceholder"
                           @onkeydown="HandleNewItemKey" 
                           @ref="_newItemInput" />
                    @if (!string.IsNullOrEmpty(_newItemError))
                    {
                        <p class="error-text mt-2">@_newItemError</p>
                    }
                </div>
                <div class="card-footer modal-footer-actions">
                    <button class="btn btn-ghost" @onclick="() => _showNewItem = false">Cancelar</button>
                    <button class="btn btn-primary" @onclick="ConfirmNewItem">Criar</button>
                </div>
            </div>
        </div>
    }

    @* CONTEXT MENU *@
    @if (_showContextMenu)
    {
        <div class="ctx-backdrop" @onclick="CloseContextMenu" @oncontextmenu="CloseContextMenu" @oncontextmenu:preventDefault="true"></div>
        <div class="context-menu-wrapper card" style="left: @(_contextMenuX)px; top: @(_contextMenuY)px;">
            @if (_contextMenuItem?.Type == WorkspaceItemType.Directory || _contextMenuItem?.Type == WorkspaceItemType.ApiProxy || _contextMenuItem?.Type == WorkspaceItemType.SharedFlow || _contextMenuItem?.Type == WorkspaceItemType.Environment)
            {
                <button class="context-menu-btn" @onclick="() => ContextAdd(false)">New File</button>
                <button class="context-menu-btn" @onclick="() => ContextAdd(true)">New Folder</button>
                <hr class="context-menu-sep" />
            }
            <button class="context-menu-btn btn-danger" @onclick="ContextDelete">Delete</button>
        </div>
    }
}