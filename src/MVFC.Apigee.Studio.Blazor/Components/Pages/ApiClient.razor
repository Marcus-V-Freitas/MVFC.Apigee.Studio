@page "/api-client"
@rendermode RenderMode.InteractiveServer

<div class="card client-container">
    <div class="request-line">
        <select class="input method-select" @bind="_method">
            <option value="GET">GET</option>
            <option value="POST">POST</option>
            <option value="PUT">PUT</option>
            <option value="DELETE">DELETE</option>
            <option value="PATCH">PATCH</option>
        </select>
        <input
            class="input flex-1"
            @bind="_url"
            placeholder="http://localhost:8998/test/v1" />
        <button
            class="btn btn-primary"
            @onclick="SendRequest"
            disabled="@_isLoading">
            @if (_isLoading)
            {
                <span>Enviando...</span>
            }
            else
            {
                <span>&#10148; Send</span>
            }
        </button>
    </div>

    <div class="request-grid">
        <div class="header-section">
            <h3>Headers</h3>
            @foreach (var header in _headers)
            {
                <div class="header-row">
                    <input
                        class="input header-name"
                        @bind="header.Key"
                        placeholder="Header Name" />
                        
                    <input
                        class="input header-value"
                        @bind="header.Value"
                        placeholder="Value" />
                    <button
                        class="btn btn-ghost btn-sm btn-danger"
                        @onclick="() => RemoveHeader(header)">
                        ✕
                    </button>
                </div>
            }
            <button
                class="btn btn-ghost btn-sm add-header-btn"
@onclick="AddHeader">
                + Add Header
            </button>
        </div>

        @if (_method == "POST" || _method == "PUT" || _method == "PATCH")
        {
            <div class="body-section">
                <h3>Body</h3>
                <textarea
                    class="input body-textarea"
                    @bind="_body"
                    placeholder='{ "key": "value" }'>
                </textarea>
            </div>
        }
    </div>
</div>

@if (_response != null)
{
    <div class="card mt-4 response-card">
        <div class="response-header">
            <h3>Response</h3>
            <div class="response-meta">
                <span>
                    Status:
                    <strong class="@(_response.IsSuccessStatusCode ? "status-success" : "status-danger")">
                        @((int)_response.StatusCode) @(_response.StatusCode)
                    </strong>
                </span>
                <span>
                    Time: <strong>@_responseTimeMs ms</strong>
                </span>
            </div>
        </div>

        <div class="response-body-section">
            <div class="response-headers-section">
                <strong>Headers:</strong>
                <pre class="response-headers-pre">
                    @string.Join("\n", _response.Headers.Select(h => $"{h.Key}: {string.Join(", ", h.Value)}"))
                </pre>
            </div>

            <textarea
                readonly
                class="input response-textarea">
                @_responseBody
            </textarea>
        </div>
    </div>
}