<div class="app-shell @(_sidebarOpen ? "sidebar-open" : "")">
    <div class="sidebar-overlay" @onclick="CloseSidebar"></div>
    
    @{
        var lastWorkspace = SessionState.Get<string>("global:lastWorkspace");
        var explorerHref = string.IsNullOrEmpty(lastWorkspace) ? "/" : $"/workspace/{Uri.EscapeDataString(lastWorkspace)}";
    }
    
    <aside class="sidebar">
        <div class="sidebar-logo">
            <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" width="26" height="26">
                <rect width="32" height="32" rx="7" fill="#4f98a3" />
                <path d="M8 24 L16 8 L24 24" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none" />
                <path d="M10.5 19h11" stroke="white" stroke-width="2" stroke-linecap="round" />
            </svg>
            <span>MVFC.Apigee.Studio</span>
        </div>
        <nav class="sidebar-nav">
            <NavLink href="/" Match="NavLinkMatch.All" class="nav-item" @onclick="CloseSidebar">
                <i data-lucide="folder-kanban" class="nav-icon"></i>
                <span>Workspaces</span>
            </NavLink>

            @if (!string.IsNullOrEmpty(lastWorkspace))
            {
                <NavLink href="@explorerHref" Match="NavLinkMatch.Prefix" class="nav-item" @onclick="CloseSidebar">
                    <i data-lucide="files" class="nav-icon"></i>
                    <span>Explorer</span>
                </NavLink>
            }

            <NavLink href="/emulator" class="nav-item" @onclick="CloseSidebar">
                <i data-lucide="terminal" class="nav-icon"></i>
                <span>Emulator</span>
            </NavLink>

            <NavLink href="/trace" class="nav-item" @onclick="CloseSidebar">
                <i data-lucide="radio" class="nav-icon"></i>
                <span>Policy Trace</span>
            </NavLink>
        </nav>
        <div class="sidebar-footer">
            <span class="sidebar-version">v1.0.0</span>
        </div>
    </aside>

    <main class="main-content">
        <header class="mobile-header">
            <button class="btn-icon" @onclick="ToggleSidebar">
                <i data-lucide="menu"></i>
            </button>
            <div class="mobile-logo">
                <svg viewBox="0 0 32 32" fill="none" width="20" height="20">
                    <rect width="32" height="32" rx="7" fill="#4f98a3" />
                    <path d="M8 24 L16 8 L24 24" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none" />
                </svg>
                <span>MVFC.Apigee.Studio</span>
            </div>
        </header>

        <div class="content-body">
            @ChildContent
        </div>
    </main>
    <ToastContainer />
</div>